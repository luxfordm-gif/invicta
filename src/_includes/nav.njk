<header class="nav">
  <nav class="container nav__inner" aria-label="Primary">
    <a class="nav__brand" href="/">Invicta<span class="nav__brand-suffix">&nbsp;Water&nbsp;Treatment</span></a>
    <button class="nav__toggle" aria-expanded="false" aria-controls="nav-links" aria-label="Open menu">
      <span aria-hidden="true"></span>
    </button>
    <ul class="nav__links" id="nav-links">
      <li class="nav__item has-menu">
        <a href="/services/private-water-supplies/"{% if current == "services" %} aria-current="page"{% endif %} aria-haspopup="true">Services <span class="nav__caret" aria-hidden="true"></span></a>
        <div class="nav__menu">
          {% for s in site.services %}
          <a href="{{ s.href }}"><strong>{{ s.title }}</strong><span>{{ s.desc }}</span></a>
          {% endfor %}
        </div>
      </li>
      <li class="nav__item has-menu">
        <a href="/sectors/"{% if current == "sectors" %} aria-current="page"{% endif %} aria-haspopup="true">Sectors <span class="nav__caret" aria-hidden="true"></span></a>
        <div class="nav__menu">
          {% for s in site.sectors %}
          <a href="{{ s.href }}"><strong>{{ s.title }}</strong><span>{{ s.desc }}</span></a>
          {% endfor %}
        </div>
      </li>
      <li class="nav__item"><a href="/about/"{% if current == "about" %} aria-current="page"{% endif %}>About</a></li>
      <li class="nav__item"><a href="/contact/"{% if current == "contact" %} aria-current="page"{% endif %}>Contact Us</a></li>
      <li class="nav__mobile-extra">
        <a class="nav__menu-cta" href="/enquiry/">Send Enquiry</a>
        <a class="nav__menu-tel" href="tel:{{ site.tel }}">
          <span>{{ site.emergencyNote }}</span>
          <strong>{{ site.phone }}</strong>
        </a>
      </li>
    </ul>
    <a class="btn-inquiry nav__cta" href="/enquiry/">Send Enquiry</a>
  </nav>
</header>
